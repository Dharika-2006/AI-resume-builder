# =========================================================================
# ResumeAI - Environment Variables Template
# Copy this file to '.env' at the root of the project to run via Docker Compose
# =========================================================================

# Database Configuration (Neon/PostgreSQL connection string)
DATABASE_URL="postgresql://username:password@hostname/dbname?sslmode=require"

# JWT Secret for Token Authentication
JWT_SECRET="your_jwt_secret_key_here"

# GROQ Cloud API Key for AI resume operations
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Frontend Build Parameter (Vite API Target)
VITE_API_URL="http://localhost:5000/api"
