// ============================================================
// AI Resume Builder SaaS - Prisma Schema
// Database: PostgreSQL (Neon compatible)
// ORM: Prisma 6.x Stable
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum ResumeTemplate {
  MODERN
  CORPORATE
  MINIMAL
}

// ============================================================
// MODELS
// ============================================================

// --- User ---------------------------------------------------
// Central entity owning resumes and ATS analysis history.
// Optimized for: Auth, future OAuth social login, multi-resume management.

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes     Resume[]
  atsAnalyses ATSAnalysis[]
}

// --- Resume -------------------------------------------------
// Core document entity. Each resume belongs to one user and
// contains one PersonalInfo and multiple section entries.
// Optimized for: Template switching, PDF export, AI rewriting.

model Resume {
  id          String         @id @default(uuid())
  title       String
  description String?
  template    ResumeTemplate @default(MODERN)
  userId      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalInfo   PersonalInfo?
  education      Education[]
  experience     Experience[]
  projects       Project[]
  skills         Skill[]
  certifications Certification[]
  atsAnalyses    ATSAnalysis[]

  @@index([userId])
}

// --- PersonalInfo -------------------------------------------
// One-to-one linked to a single Resume.
// Optimized for: Resume upload parsing (auto-fill on PDF/DOCX import).

model PersonalInfo {
  id        String  @id @default(uuid())
  name      String
  email     String
  phone     String?
  location  String?
  linkedin  String?
  github    String?
  portfolio String?
  summary   String?
  resumeId  String  @unique

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// --- Education ----------------------------------------------
// Many education entries per resume.
// Optimized for: Degree history, GPA/CGPA tracking.

model Education {
  id          String  @id @default(uuid())
  degree      String
  institution String
  year        String
  cgpa        String?
  resumeId    String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// --- Experience ---------------------------------------------
// Many work experience entries per resume.
// Optimized for: AI bullet point generation, job description matching.

model Experience {
  id          String  @id @default(uuid())
  role        String
  company     String
  startDate   String
  endDate     String?
  description String
  resumeId    String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// --- Project ------------------------------------------------
// Many projects per resume.
// Optimized for: Tech stack ATS matching, GitHub/live link display.

model Project {
  id          String  @id @default(uuid())
  name        String
  techStack   String
  description String
  githubLink  String?
  liveLink    String?
  resumeId    String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// --- Skill --------------------------------------------------
// Many skill entries per resume (single skill per row for flexible querying).
// Optimized for: ATS keyword matching, AI skill suggestions.

model Skill {
  id       String @id @default(uuid())
  name     String
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// --- Certification ------------------------------------------
// Many certifications per resume.
// Optimized for: Credential tracking, display in PDF export.

model Certification {
  id       String @id @default(uuid())
  name     String
  issuer   String
  year     String
  resumeId String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// --- ATSAnalysis --------------------------------------------
// Historical ATS scoring records linked to both User and optionally a Resume.
// resumeId is optional — allows analyses run before a resume is saved.
// Optimized for: Score history, AI improvement suggestions, keyword audit.

model ATSAnalysis {
  id                  String   @id @default(uuid())
  score               Int
  scoreLabel          String   @default("Needs Improvement")
  keywordMatchPercent Float
  matchedKeywords     String[]
  missingKeywords     String[]
  strengths           String[]
  suggestions         String[]
  breakdown           Json?
  userId              String
  resumeId            String?
  createdAt           DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resumeId])
}
